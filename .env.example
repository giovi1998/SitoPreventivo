# DeepSeek API Key — server-side only
# Ottieni una chiave su https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Admin password — usata ESCLUSIVAMENTE via env var (Vercel: ADMIN_PASSWORD, locale: VITE_ADMIN_PASSWORD)
# L'admin è sempre admin@gmail.com, la password non viene salvata su database
# Requisiti: minimo 12 caratteri, 1 maiuscola, 1 minuscola, 1 numero, 1 carattere speciale
ADMIN_PASSWORD=

# Stessa password sopra, ma con prefisso VITE_ per accesso client-side (locale)
VITE_ADMIN_PASSWORD=

# Database — Neon / Vercel Postgres connection string (server-side only)
DATABASE_URL=

# Origine autorizzata per CORS in produzione (es. https://tuodominio.vercel.app)
# In dev è sempre '*'. Se vuoto, accetta solo *.vercel.app
ALLOWED_ORIGIN=
