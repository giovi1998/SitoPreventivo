# DeepSeek API Key — server-side only
# Ottieni una chiave su https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# JWT Secret — da implementare in futuro
# Usa: node -e "console.log(crypto.randomUUID())"
JWT_SECRET=

# Admin initial password — usata sia dal server (Netlify functions) che dal client (locale)
# Requisiti: minimo 12 caratteri, 1 maiuscola, 1 minuscola, 1 numero, 1 carattere speciale
ADMIN_INITIAL_PASSWORD=

# Stessa password sopra, ma con prefisso VITE_ per accesso client-side (locale)
# In locale viene letta da import.meta.env.VITE_ADMIN_INITIAL_PASSWORD
VITE_ADMIN_INITIAL_PASSWORD=
